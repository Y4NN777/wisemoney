{
  "name": "wisemoney",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first personal-finance PWA — AI guidance + financial literacy",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20 <21",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @wisemoney/web dev",
    "build": "pnpm --filter @wisemoney/web build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  }
}
