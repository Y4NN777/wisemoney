# WiseMoney — environment template.
# Copy to .env and fill. NEVER commit .env. For real secrets use SOPS/age (see SECURITY.md).
# The Go edge needs these only for MANAGED mode; BYO-key mode runs fully client-side.

# --- Postgres (auth + refresh tokens only — NO financial data) ---
POSTGRES_USER=wisemoney
POSTGRES_PASSWORD=change-me-in-real-env
POSTGRES_DB=wisemoney_edge
# DATABASE_URL is consumed by the edge; host is the compose service name 'postgres'.
DATABASE_URL=postgres://wisemoney:change-me-in-real-env@postgres:5432/wisemoney_edge?sslmode=disable

# --- Edge service ---
EDGE_PORT=8080
# JWT signing key (server-only; INV-AUTH-03). Generate a strong random value.
JWT_SIGNING_KEY=change-me-32-bytes-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Consent-assertion signing (AQ-01; ARCHITECTURE §10a). DEDICATED key — MUST differ
# from JWT_SIGNING_KEY (independent rotation, Gate-5). >= 32 bytes.
CONSENT_SIGNING_KEY=change-me-different-from-jwt-32b
CONSENT_ASSERTION_TTL=5m

# Argon2id password-hash parameters (INV-AUTH-02). Tune to the host.
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# Per-user rate limit (in-memory token bucket; Gate-4 #20).
RATE_LIMIT_RPS=2
RATE_LIMIT_BURST=10

# --- Managed-mode AI provider keys (server-side only; never sent to the client) ---
GEMINI_API_KEY=
NVIDIA_NIM_API_KEY=
OPENAI_API_KEY=

# --- Web (Vite) ---
# Base URL the PWA uses to reach the managed edge (managed mode only).
VITE_EDGE_BASE_URL=http://localhost:8080
